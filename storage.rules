rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /receipts/{userId}/{allPaths=**} {
      // Allow user to read their own receipts, or authenticated users (admins) to read all
      // We simplify the admin check to just isAuthenticated() for now to avoid firestore.get timeouts
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
